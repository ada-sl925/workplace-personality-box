# 数据分析配置
# 复制此文件为 .env.local（开发环境）或在 Vercel 中设置环境变量

# 基础配置
ANALYTICS_ENABLED=true
# 隐私设置：是否默认启用匿名化
ANALYTICS_DEFAULT_ANONYMIZE=true

# Google Analytics 4 配置
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=your_api_secret_here

# 自定义 Webhook URL（将数据发送到自定义端点）
# ANALYTICS_WEBHOOK_URL=https://your-webhook-endpoint.com/analytics

# Supabase 配置（推荐用于生产环境）
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MongoDB Atlas 配置（备选方案）
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# 其他配置
# 数据保留天数（默认30天）
ANALYTICS_RETENTION_DAYS=30