{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/analytics/log.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/analytics/stats.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/analytics/data.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/analytics/(.*)",
      "dest": "/api/analytics/$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "github": {
    "silent": true
  },
  "env": {
    "VITE_APP_TITLE": "职场性格盲盒",
    "VITE_API_URL": "",
    "VITE_ANALYTICS_ENABLED": "true",
    "VITE_ANALYTICS_DEFAULT_ANONYMIZE": "true"
  }
}